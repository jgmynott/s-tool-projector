# s-tool.io backend environment
# Copy to .env for local dev. On Railway, set these via the dashboard.

# ── Data providers ────────────────────────────────────────────────
FMP_API_KEY=
FINNHUB_API_KEY=
POLYGON_API_KEY=
FRED_API_KEY=
ALPHA_VANTAGE_API_KEY=

# ── Clerk (auth) ──────────────────────────────────────────────────
# Get these at https://dashboard.clerk.com → your instance → API Keys.
# The publishable key is safe in client code; the secret must stay server-side.
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
# Your Clerk instance's JWKS endpoint. Default points at Clerk's Frontend API;
# override if you use a custom domain.
# Example: https://clerk.s-tool.io/.well-known/jwks.json
CLERK_JWKS_URL=

# ── Stripe (billing) ──────────────────────────────────────────────
# Test keys for dev. Live keys go directly in Railway env vars, never here.
STRIPE_SK=sk_test_...
STRIPE_PK=pk_test_...
# Signing secret for webhook payloads. Copy from Stripe dashboard after
# registering your webhook endpoint (/api/billing/webhook).
STRIPE_WEBHOOK_SECRET=whsec_...
# Price ID of the Pro subscription. Create in Stripe dashboard
# → Products → s-tool Pro → copy the recurring price ID.
STRIPE_PRICE_ID_PRO=price_...

# ── Runtime ───────────────────────────────────────────────────────
# Allow-list for CORS in production. Comma-separated, no spaces.
CORS_ORIGINS=https://s-tool.io,https://www.s-tool.io,http://localhost:8000
